<defs>
<filter id="filter0_fn_0_4" x="0" y="0" width="6080" height="6080" filterUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
<feFlood flood-opacity="0" result="BackgroundImageFix"/>
