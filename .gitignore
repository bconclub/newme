# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# mcp secrets
mcp.json

# figma exports (regenerated via scripts/pull-figma.mjs)
/figma/
figma-pull.log

# scratch / temp artefacts pulled from Figma MCP during dev
.figma-*.png
.tmp-page.html

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local scratch — Figma screenshot downloads
.figma-temp/
.codex-temp-index-commit
